{
  "name": "jigar-tecmantras/bmi-backend",
  "description": "Laravel API for BMI calculation",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "fruitcake/laravel-cors": "^3.0",
    "laravel/framework": "^10.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.9",
    "laravel/pint": "^1.0",
    "laravel/sail": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  }
}
